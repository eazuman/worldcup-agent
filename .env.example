
# Google Gemini — https://ai.google.dev/gemini-api/docs/api-key
GOOGLE_API_KEY=your-gemini-api-key-here

# football-data.org — https://www.football-data.org/client/register
FOOTBALL_DATA_KEY=your-football-data-org-key-here

# API-Football (api-sports.io) — https://www.api-football.com/ — today's games,
# live scores and results. World Cup is league 1; season is the tournament year.
API_FOOTBALL_KEY=your-api-football-key-here
# API_FOOTBALL_LEAGUE=1
# API_FOOTBALL_SEASON=2026
